# direnv configuration for DJ Toolkit
# Auto-activates the local .venv when you cd into this directory.
#
# Setup (one-time):
#   1. Install direnv:            sudo apt install direnv
#   2. Add shell hook to ~/.bashrc or ~/.zshrc:
#        eval "$(direnv hook bash)"   # bash
#        eval "$(direnv hook zsh)"    # zsh
#   3. Allow this file:           direnv allow .
#
# After setup, entering this directory will automatically activate .venv.
# Leaving the directory deactivates it.

source_env_if_exists .env

if [ -d .venv ]; then
  source .venv/bin/activate
fi
